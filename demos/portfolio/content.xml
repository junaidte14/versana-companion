    <item>
        <title>Brand Identity for Tech Startup</title>
        <link>https://demos.codoplex.com/versana/portfolio/tech-startup-branding</link>
        <pubDate>Tue, 20 Feb 2024 10:00:00 +0000</pubDate>
        <dc:creator><![CDATA[admin]]></dc:creator>
