          }
        }
      },
      "h1": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.1"
        },
        "color": {
          "text": "var(--wp--preset--color--neutral-900)"
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--neutral-900)"
        }
      },
      "h3": {
